generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Perfil {
  ADMINISTRADOR
  PREFEITURA
  CIDADAO
}

model Usuario {
  id              Int        @id @default(autoincrement())
  nome            String
  email           String     @unique
  cpf             String?    @unique
  senha           String
  perfil          Perfil     @default(CIDADAO)
  ativo           Boolean    @default(true)
  
  dataCriacao     DateTime   @default(now()) @map("data_criacao")
  dataAtualizacao DateTime   @updatedAt @map("data_atualizacao")
  
  denuncias       Denuncia[] 

  movimentacoes  Movimentacao[]

  @@map("usuarios")
}

model Categoria {
  id              Int        @id @default(autoincrement())
  nome            String     @unique
  descricao       String?
  ativo           Boolean    @default(true)
  
  dataCriacao     DateTime   @default(now()) @map("data_criacao")
  dataAtualizacao DateTime   @updatedAt @map("data_atualizacao")
  
  denuncias       Denuncia[]

  @@map("categorias")
}

model Denuncia {
  id              Int        @id @default(autoincrement())
  descricao       String
  latitude        Float
  longitude       Float
  
  // Novos campos de endereço
  cep             String?
  logradouro      String?
  numero          String?
  complemento     String?
  bairro          String?
  cidade          String?
  estado          String?
  pontoReferencia String? @map("ponto_referencia")

  status          String     @default("ABERTA") // ABERTA, EM_ANALISE, RESOLVIDA
  midiaUrl        String?    @map("midia_url")
  anonima         Boolean    @default(false)
  
  dataCriacao     DateTime   @default(now()) @map("data_criacao")
  dataAtualizacao DateTime   @updatedAt @map("data_atualizacao")

  usuarioId       Int?       @map("usuario_id")
  usuario         Usuario?   @relation(fields: [usuarioId], references: [id])
  
  categoriaId     Int        @map("categoria_id")
  categoria       Categoria  @relation(fields: [categoriaId], references: [id])

  movimentacoes  Movimentacao[]

  @@map("denuncias")
}

model Movimentacao {
  id              Int      @id @default(autoincrement())
  mensagem        String   @db.Text // @db.Text permite textos mais longos que o String padrão
  
  // Campos opcionais super úteis para criar uma timeline rica:
  // Ex: "A prefeitura mudou de EM_ANALISE para EM_ANDAMENTO"
  statusAnterior  String?  
  statusNovo      String?  
  
  dataCriacao     DateTime   @default(now()) @map("data_criacao")

  // Relacionamento 1 (A qual denúncia esta mensagem pertence?)
  denunciaId      Int
  denuncia        Denuncia @relation(fields: [denunciaId], references: [id], onDelete: Cascade)

  // Relacionamento 2 (Quem escreveu? Pode ser o atendente da prefeitura ou o próprio cidadão respondendo)
  usuarioId         Int
  usuario           Usuario     @relation(fields: [usuarioId], references: [id])

  @@map("movimentacoes")
}